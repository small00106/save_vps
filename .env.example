# Docker image tag published to GHCR.
CLOUDNEST_IMAGE_TAG=latest

# Host port exposed by docker compose.
CLOUDNEST_PORT=8800

# Runtime database configuration inside the container.
CLOUDNEST_DB_TYPE=sqlite
CLOUDNEST_DB_DSN=/app/data/cloudnest.db

# Public URL used when Master generates Agent install commands.
# Example: https://ops.example.com
CLOUDNEST_PUBLIC_BASE_URL=
